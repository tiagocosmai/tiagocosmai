# === Servidor / Vercel (nunca commitar valores reais) ===
RESEND_API_KEY=re_xxxxxxxx
# Domínio verificado no Resend, ex: "Portfolio <mail@seudominio.com>"
# Testes: use onboarding@resend.dev (só envia para o teu email de conta Resend)
RESEND_FROM=Portfolio <onboarding@resend.dev>
# Onde recebes as mensagens
CONTACT_TO=you@example.com

# Porta do API local (opcional)
# CONTACT_API_PORT=8787

# === Frontend (só se a API estiver noutro domínio) ===
# URL completa do endpoint, ex. deploy Vercel só da API ou Railway:
# VITE_CONTACT_API_URL=https://teu-projeto.vercel.app/api/contact
# Em dev com proxy + npm run dev:all, deixa vazio.
